---
const installUrl = "https://alpbak.github.io/bakend/install.sh";
const repo = "alpbak/bakend";
---

<div class="install-block">
  <h3>Install</h3>
  <pre><code># One-liner (Linux / macOS)
curl -fsSL {installUrl} | sudo sh

# Or clone and run locally
git clone https://github.com/{repo}.git
cd bakend
sudo sh scripts/install.sh</code></pre>
  <p class="install-note">
    See <a href={`https://github.com/${repo}/blob/main/docs/user-guide/installation.md`}>installation guide</a>
    for Docker, development setup, and project scaffolding with <code>bak init</code>.
  </p>
</div>

<style>
  .install-note {
    font-size: 0.875rem;
    color: var(--muted);
    margin-top: 0.75rem;
  }
</style>
