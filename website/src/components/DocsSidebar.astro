---
import { docsNav, docsHref, tutorialsNav, tutorialsHref } from "../lib/docs-nav";

interface Props {
  section: "docs" | "tutorials";
  currentSlug: string;
}

const { section, currentSlug } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<aside class="docs-sidebar" id="docs-sidebar">
  <button type="button" class="sidebar-close" id="sidebar-close" aria-label="Close navigation">
    &times;
  </button>
  {
    section === "docs" ? (
      docsNav.map((group) => (
        <div class="sidebar-group">
          <p class="sidebar-group-title">{group.title}</p>
          <ul>
            {group.items.map((item) => (
              <li>
                <a
                  href={docsHref(base, item.slug)}
                  class:list={["sidebar-link", { active: item.slug === currentSlug }]}
                >
                  {item.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))
    ) : (
      <div class="sidebar-group">
        <p class="sidebar-group-title">Tutorials</p>
        <ul>
          {tutorialsNav.map((item) => (
            <li>
              <a
                href={tutorialsHref(base, item.slug)}
                class:list={["sidebar-link", { active: item.slug === currentSlug }]}
              >
                {item.title}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )
  }
</aside>

<style>
  .docs-sidebar {
    width: 260px;
    flex-shrink: 0;
    padding: 1.5rem 1rem 2rem 1.5rem;
    border-right: 1px solid var(--border);
    background: var(--surface);
    overflow-y: auto;
    max-height: calc(100vh - 57px);
    position: sticky;
    top: 57px;
  }

  .sidebar-close {
    display: none;
  }

  .sidebar-group {
    margin-bottom: 1.25rem;
  }

  .sidebar-group-title {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
    margin-bottom: 0.5rem;
    padding: 0 0.5rem;
  }

  .sidebar-group ul {
    list-style: none;
  }

  .sidebar-link {
    display: block;
    padding: 0.35rem 0.5rem;
    border-radius: 6px;
    font-size: 0.875rem;
    color: var(--muted);
    text-decoration: none;
    line-height: 1.4;
  }

  .sidebar-link:hover {
    color: var(--text);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
    text-decoration: none;
  }

  .sidebar-link.active {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    font-weight: 500;
  }

  @media (max-width: 900px) {
    .docs-sidebar {
      position: fixed;
      top: 0;
      left: 0;
      z-index: 100;
      height: 100vh;
      max-height: none;
      transform: translateX(-100%);
      transition: transform 0.2s ease;
      box-shadow: 4px 0 24px color-mix(in srgb, var(--text) 10%, transparent);
    }

    :global(.docs-sidebar-open) .docs-sidebar {
      transform: translateX(0);
    }

    .sidebar-close {
      display: block;
      position: absolute;
      top: 0.75rem;
      right: 0.75rem;
      background: none;
      border: none;
      font-size: 1.5rem;
      color: var(--muted);
      cursor: pointer;
      line-height: 1;
    }
  }
</style>
