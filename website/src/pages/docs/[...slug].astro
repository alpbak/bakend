---
import { getCollection, render } from "astro:content";
import DocsLayout from "../../layouts/DocsLayout.astro";
import DocsPager from "../../components/DocsPager.astro";
import { entryIdToSlug, getDocsNeighbors, docsHref } from "../../lib/docs-nav";
import { extractTitle } from "../../lib/docs-utils";

export async function getStaticPaths() {
  const entries = await getCollection("docs");

  return entries
    .map((entry) => {
      const urlSlug = entryIdToSlug(entry.id);
      if (urlSlug === null) return null;
      return {
        params: { slug: urlSlug },
        props: { entry },
      };
    })
    .filter((path): path is NonNullable<typeof path> => path !== null);
}

const base = import.meta.env.BASE_URL;
const { entry } = Astro.props;
const currentSlug = Astro.params.slug ?? "";
const { Content, headings } = await render(entry);
const title = extractTitle(entry);
const { prev, next } = getDocsNeighbors(currentSlug);
---

<DocsLayout
  title={`${title} — Bakend Docs`}
  section="docs"
  currentSlug={currentSlug}
  {headings}
  breadcrumbs={[
    { label: "Docs", href: docsHref(base, "") },
    { label: title },
  ]}
>
  <Content />
  <DocsPager
    slot="footer"
    prev={prev ? { title: prev.title, href: docsHref(base, prev.slug) } : null}
    next={next ? { title: next.title, href: docsHref(base, next.slug) } : null}
  />
</DocsLayout>
