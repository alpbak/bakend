---
import { getEntry, render } from "astro:content";
import DocsLayout from "../layouts/DocsLayout.astro";
import DocsPager from "../components/DocsPager.astro";
import { getDocsNeighbors, docsHref } from "../lib/docs-nav";
import { extractTitle } from "../lib/docs-utils";

const base = import.meta.env.BASE_URL;
const entry = await getEntry("docs", "readme");
if (!entry) throw new Error("docs README not found");

const { Content, headings } = await render(entry);
const title = extractTitle(entry);
const { prev, next } = getDocsNeighbors("");
---

<DocsLayout
  title="Documentation — Bakend"
  description="Bakend documentation hub"
  section="docs"
  currentSlug=""
  {headings}
  breadcrumbs={[{ label: "Docs" }]}
>
  <Content />
  <DocsPager
    slot="footer"
    prev={prev ? { title: prev.title, href: docsHref(base, prev.slug) } : null}
    next={next ? { title: next.title, href: docsHref(base, next.slug) } : null}
  />
</DocsLayout>
