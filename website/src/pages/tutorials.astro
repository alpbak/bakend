---
import { getEntry, render } from "astro:content";
import DocsLayout from "../layouts/DocsLayout.astro";
import DocsPager from "../components/DocsPager.astro";
import { getTutorialNeighbors, tutorialsHref } from "../lib/docs-nav";
import { extractTitle } from "../lib/docs-utils";

const base = import.meta.env.BASE_URL;
const entry = await getEntry("tutorials", "readme");
if (!entry) throw new Error("tutorials README not found");

const { Content, headings } = await render(entry);
const title = extractTitle(entry);
const { prev, next } = getTutorialNeighbors("");
---

<DocsLayout
  title="Tutorials — Bakend"
  description="Step-by-step Bakend tutorials"
  section="tutorials"
  currentSlug=""
  {headings}
  breadcrumbs={[{ label: "Tutorials" }]}
>
  <Content />
  <DocsPager
    slot="footer"
    prev={prev ? { title: prev.title, href: tutorialsHref(base, prev.slug) } : null}
    next={next ? { title: next.title, href: tutorialsHref(base, next.slug) } : null}
  />
</DocsLayout>
