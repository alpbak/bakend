{
  "name": "@bakend/client",
  "version": "1.0.0",
  "description": "Bakend client SDK for JavaScript and TypeScript",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --format esm && tsc -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alpbak/bakend.git",
    "directory": "sdk/javascript"
  },
  "homepage": "https://alpbak.github.io/bakend/",
  "bugs": {
    "url": "https://github.com/alpbak/bakend/issues"
  },
  "keywords": [
    "bakend",
    "backend",
    "sqlite",
    "realtime",
    "sdk"
  ],
  "license": "MIT"
}
